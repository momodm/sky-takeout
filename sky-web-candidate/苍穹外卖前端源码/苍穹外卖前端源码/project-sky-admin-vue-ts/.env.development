# Candidate admin uses the current backend's /admin prefix via the local /api proxy.
VUE_APP_BASE_API = '/api'

NODE_ENV = 'development'
VUE_APP_NODE_ENV = 'parallel-dev'

# Current Spring Boot backend admin entry.
VUE_APP_URL = 'http://127.0.0.1:8080/admin'

# Current websocket endpoint for admin order reminders.
VUE_APP_SOCKET_URL = 'ws://127.0.0.1:8080/ws/admin/orders?clientId='

VUE_CLI_BABEL_TRANSPILE_MODULES = true
VUE_APP_DELETE_PERMISSIONS = true
